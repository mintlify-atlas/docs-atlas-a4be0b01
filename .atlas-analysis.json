    "PUT /api/client/update-job/:id",
    "POST /api/client/payment/:jobId",
    "POST /api/client/create-contract/:jobId",
    "PATCH /api/client/release-fund/:contractId",
    "POST /api/client/rate-freelancer/:clientId",
    "POST /api/freelancer/apply-job/:jobId",
    "GET /api/freelancer/applied-jobs",
    "GET /api/freelancer/earnings/:userId",
    "GET /api/freelancer/transactions/:walletId",
    "GET /api/admin/total-revenue",
    "GET /api/admin/balance",
    "PUT /api/admin/release-fund/:contractId",
    "PUT /api/admin/refund-client/:contractId/:clientId",
    "POST /api/media/upload"
  ]
