  "keyFeatures": [
    "Role-based authentication (Freelancer, Client, Admin) using JWT with Google OAuth support",
    "Escrow wallet system with Stripe payment integration for secure fund holding, release, and refund",
    "Full project and contract lifecycle management from job posting to completion",
    "Real-time chat between clients and freelancers via Socket.io with media sharing",
    "Smart bot assistant for handling common queries",
    "Proposal and offer workflow for job applications",
    "Admin dashboard with revenue, escrow balance, and user tracking",
    "OTP-based email verification and password reset via Redis and Nodemailer",
    "Freelancer reviews and ratings system",
    "Cloudinary media storage for profile images and chat attachments"
  ],
  "publicApiSurface": [
    "POST /api/auth/register",
    "POST /api/auth/login",
    "POST /api/auth/google-login",
    "POST /api/auth/verify-otp",
    "POST /api/auth/forgot-password",
